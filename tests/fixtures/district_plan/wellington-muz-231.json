  {
   "ruleId": 8048,
   "ruleLevel": 1,
   "title": null,
   "ruleText": "<table style=\"width: 100%\">\n<tbody>\n<tr>\n<td style=\"width: 15%\" align=\"center\">\n<p><b>MUZ-O1</b></p>\n</td>\n<td style=\"width: 85%\">\n<p><b>Purpose </b></p>\n<p><b>&nbsp;</b></p>\n<p>The Mixed Use Zone is developed and used for a wide range of compatible activities.<span style=\"background-color: rgba(0, 0, 0, 0); font-size: 10pt\">&nbsp;</span></p>\n</td>\n</tr>\n</tbody>\n</table>",
   "ruleComments": null,
