  {
   "ruleId": 8346,
   "ruleLevel": 1,
   "title": null,
   "ruleText": "<table style=\"width: 100%\">\n<tbody>\n<tr>\n<td style=\"width: 15%\" align=\"center\">\n<p><b>GIZ-P4</b></p>\n</td>\n<td style=\"width: 85%\">\n<p><b><a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>Commercial activities</a></b></p>\n<p>&nbsp;</p>\n<p>Avoid <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>commercial activities</a> in the General Industrial Zone except for:</p>\n<p>&nbsp;</p>\n<ol>\n<li>Office, retail and other <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>commercial activities</a> which are ancillary to <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>industrial activities</a>; and</li>\n<li><a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>Trade supply retail</a>, <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>wholesalers</a>, <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>building improvement centres</a>, <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>service retail</a> and <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>yard based retail</a>.&nbsp; &nbsp;</li>\n</ol>\n</td>\n</tr>\n</tbody>\n</table>",
   "ruleComments": null,
