  {
   "ruleId": 8352,
   "ruleLevel": 1,
   "title": null,
   "ruleText": "<table style=\"width: 100%\">\n<tbody>\n<tr>\n<td style=\"width: 2%; background-color: #92d050\">\n<p>&nbsp;</p>\n</td>\n<td style=\"width: 98%\">\n<ol>\n<li>Activity status: <b>Permitted<br><br></b>Where:<br><br>\n<ol style=\"list-style-type: lower-alpha\">\n<li><span style=\"background-color: transparent; font-size: 10pt\">The activity is not a </span><a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>heavy industrial activity</a><i>; </i><span style=\"background-color: transparent; font-size: 10pt\">and</span></li>\n<li>Any ancillary <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>retail activity</a> is limited to the display and sale of goods produced, processed or stored on the <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>site</a> and does not exceed 10% of the <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>gross floor area</a> of all <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>buildings</a> on the <a href='' role='button' class='divRuleTextDef' onruleclick='scrolltoDefinition(event)'>site</a>.&nbsp;</li>\n</ol>\n</li>\n</ol>\n</td>\n</tr>\n</tbody>\n</table>",
