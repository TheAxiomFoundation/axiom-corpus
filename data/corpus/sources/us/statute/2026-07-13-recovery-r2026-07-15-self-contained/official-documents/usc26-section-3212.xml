  <ns0:title id="id4016a4d7-3a70-11f1-a967-d35dac11796a" identifier="/us/usc/t26">
    <ns0:num value="26">Title 26—</ns0:num>
    <ns0:heading>INTERNAL REVENUE CODE</ns0:heading>
    <ns0:section style="-uslm-lc:I80" id="id4571cd72-3a70-11f1-a967-d35dac11796a" identifier="/us/usc/t26/s3212">
      <ns0:num value="3212">§ 3212.</ns0:num>
      <ns0:heading> Determination of compensation</ns0:heading>
      <ns0:content>
        <ns0:p style="-uslm-lc:I11" class="indent0">The compensation of an employee representative for the purpose of ascertaining the tax thereon shall be determined in the same manner and with the same effect as if the employee organization by which such employee representative is employed were an employer as defined in section 3231(a).</ns0:p>
      </ns0:content>
      <ns0:sourceCredit id="id4571cd73-3a70-11f1-a967-d35dac11796a">(<ns0:ref href="/us/act/1954-08-16/ch736">Aug. 16, 1954, ch. 736</ns0:ref>, <ns0:ref href="/us/stat/68A/432">68A Stat. 432</ns0:ref>.)</ns0:sourceCredit>
    </ns0:section>
