  <ns0:title id="id4016a4d7-3a70-11f1-a967-d35dac11796a" identifier="/us/usc/t26">
    <ns0:num value="26">Title 26—</ns0:num>
    <ns0:heading>INTERNAL REVENUE CODE</ns0:heading>
    <ns0:section style="-uslm-lc:I80" id="id45a3d952-3a70-11f1-a967-d35dac11796a" identifier="/us/usc/t26/s3503">
      <ns0:num value="3503">§ 3503.</ns0:num>
      <ns0:heading> Erroneous payments</ns0:heading>
      <ns0:content>
        <ns0:p style="-uslm-lc:I11" class="indent0">Any tax paid under chapter 21 or 22 by a taxpayer with respect to any period with respect to which he is not liable to tax under such chapter shall be credited against the tax, if any, imposed by such other chapter upon the taxpayer, and the balance, if any, shall be refunded.</ns0:p>
      </ns0:content>
      <ns0:sourceCredit id="id45a3d953-3a70-11f1-a967-d35dac11796a">(<ns0:ref href="/us/act/1954-08-16/ch736">Aug. 16, 1954, ch. 736</ns0:ref>, <ns0:ref href="/us/stat/68A/471">68A Stat. 471</ns0:ref>.)</ns0:sourceCredit>
    </ns0:section>
  </ns0:title>
