  <ns0:title id="id4016a4d7-3a70-11f1-a967-d35dac11796a" identifier="/us/usc/t26">
    <ns0:num value="26">Title 26—</ns0:num>
    <ns0:heading>INTERNAL REVENUE CODE</ns0:heading>
    <ns0:section style="-uslm-lc:I80" id="id41327577-3a70-11f1-a967-d35dac11796a" identifier="/us/usc/t26/s64">
      <ns0:num value="64">§ 64.</ns0:num>
      <ns0:heading> Ordinary income defined</ns0:heading>
      <ns0:content>
        <ns0:p style="-uslm-lc:I11" class="indent0">For purposes of this subtitle, the term “ordinary income” includes any gain from the sale or exchange of property which is neither a capital asset nor property described in section 1231(b). Any gain from the sale or exchange of property which is treated or considered, under other provisions of this subtitle, as “ordinary income” shall be treated as gain from the sale or exchange of property which is neither a capital asset nor property described in section 1231(b).</ns0:p>
      </ns0:content>
      <ns0:sourceCredit id="id41327578-3a70-11f1-a967-d35dac11796a">(Added <ns0:ref href="/us/pl/94/455/tXIX/s1901/a/10">Pub. L. 94–455, title XIX, § 1901(a)(10)</ns0:ref>, <ns0:date date="1976-10-04">Oct. 4, 1976</ns0:date>, <ns0:ref href="/us/stat/90/1765">90 Stat. 1765</ns0:ref>.)</ns0:sourceCredit>
    </ns0:section>
