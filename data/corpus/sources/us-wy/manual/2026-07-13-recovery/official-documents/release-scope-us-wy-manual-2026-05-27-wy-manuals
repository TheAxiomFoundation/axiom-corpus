            <div post_id="72" itemcount="15"  header_id="header-1567906525976" id="header-1567906525976" style="" class="accordions-head head1567906525976 border-none" toggle-text="" main-text="1700 Power Benefit Limits">
                                    <span id="accordion-icons-1567906525976" class="accordion-icons">
                        <span class="accordion-icon-active accordion-plus"><i class="fa fas fa-chevron-up"></i></span>
