                    <a id="ctl00_PageBody_linkPrint" title="Printable Version" href="LawPrint.aspx?d=101769" target="_blank"><img title="Printable Version" src="App_Themes/Legis/Images/print.gif" alt="" style="border-width:0px;"></a>
