></OrderedList></xhtml:td><xhtml:td rowspan="1" colspan="1"><OrderedList Decoration="parens" Type="roman" Start="2"><ListItem><Para><Text>   <Substitution ChangeId="key-a7" CommentaryRef="key-a7">£172.10</Substitution>.</Text></Para></ListItem></OrderedList></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td rowspan="1" colspan="1"><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/4/paragraph/2n2" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4/paragraph/2n2" id="schedule-2-part-4-paragraph-2n2" shortId="schedule-2-paragraph-2"><Pnumber>2</Pnumber><P2para><Text>Enhanced disability premium.</Text></P2para></P2></xhtml:td><xhtml:td rowspan="1" colspan="1"><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/4/paragraph/2n3" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4/paragraph/2n3" id="schedule-2-part-4-paragraph-2n3" shortId="schedule-2-paragraph-2"><Pnumber>2</Pnumber><P2para><Text>   <Substitution ChangeId="key-a8" CommentaryRef="key-a8">£33.99</Substitution> in respect of each child or young person in respect of whom the conditions specified in paragraph 7 are satisfied.</Text></P2para></P2></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td rowspan="1" colspan="1"><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/4/paragraph/3n2" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4/paragraph/3n2" id="schedule-2-part-4-paragraph-3n2" shortId="schedule-2-paragraph-3"><Pnumber>3</Pnumber><P2para><Text>Disabled Child Premium.</Text></P2para></P2></xhtml:td><xhtml:td rowspan="1" colspan="1"><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/4/paragraph/3n3" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4/paragraph/3n3" id="schedule-2-part-4-paragraph-3n3" shortId="schedule-2-paragraph-3"><Pnumber>3</Pnumber><P2para><Text>   <Substitution ChangeId="key-a9" CommentaryRef="key-a9">£84.46</Substitution> in respect of each child or young person in respect of whom the condition specified in paragraph 8 is satisfied</Text></P2para></P2></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td xmlns:fo="http://www.w3.org/1999/XSL/Format" rowspan="1" colspan="1" fo:border-bottom-style="solid" fo:border-bottom-width="0.5pt" fo:border-bottom-color="black"><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/4/paragraph/4n2" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4/paragraph/4n2" id="schedule-2-part-4-paragraph-4n2" shortId="schedule-2-paragraph-4"><Pnumber>4</Pnumber><P2para><Text>Carer Premium.</Text></P2para></P2></xhtml:td><xhtml:td xmlns:fo="http://www.w3.org/1999/XSL/Format" rowspan="1" colspan="1" fo:border-bottom-style="solid" fo:border-bottom-width="0.5pt" fo:border-bottom-color="black"><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/4/paragraph/4n3" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4/paragraph/4n3" id="schedule-2-part-4-paragraph-4n3" shortId="schedule-2-paragraph-4"><Pnumber>4</Pnumber><P2para><Text>   <Substitution ChangeId="key-a10" CommentaryRef="key-a10">£48.15</Substitution> in respect of each person who satisfies the condition specified in paragraph 9.</Text></P2para></P2></xhtml:td></xhtml:tr></xhtml:tbody></xhtml:table></Tabular></Part></ScheduleBody></Schedule></Schedules></Secondary><Commentaries><Commentary Type="I" id="key-a1"><Para><Text>Sch. 2 Pt. 4  in force at 27.11.2012, see <CitationSubRef id="n5f427daacde74bad" SectionRef="regulation-1-1" URI="http://www.legislation.gov.uk/id/uksi/2012/2885/regulation/1/1" Operative="true">reg. 1(1)</CitationSubRef></Text></Para></Commentary><Commentary id="key-a4" Type="F"><Para><Text>Words in <CitationSubRef id="ccd8e220241023162122680100" URI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/4" SectionRef="schedule-2-part-4">Sch. 2 Pt. 4</CitationSubRef> Table inserted 