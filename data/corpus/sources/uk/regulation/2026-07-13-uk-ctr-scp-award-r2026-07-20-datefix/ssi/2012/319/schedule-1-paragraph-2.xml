				</ukm:Metadata><Secondary><Schedules RestrictStartDate="2026-04-01"><Schedule DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1" NumberOfProvisions="12" id="schedule-1" RestrictExtent="S" RestrictStartDate="2026-04-01"><Number>SCHEDULE 1</Number><TitleBlock><Title>Applicable amount</Title></TitleBlock><ScheduleBody><Part DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1/part/1" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/part/1" NumberOfProvisions="3" id="schedule-1-part-1" RestrictStartDate="2026-04-01"><Number><Strong>PART 1</Strong></Number><Title>Personal allowances</Title><P1 DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1/paragraph/2" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/paragraph/2" id="schedule-1-paragraph-2" RestrictExtent="S" RestrictStartDate="2026-04-01"><Pnumber>2</Pnumber><P1para><Text>The amount specified in column (2) below in respect of each person or couple specified in column (1) is the amount specified for the purposes of regulation 20(a) (applicable amount)—</Text></P1para><Tabular Orientation="portrait"><xhtml:table xmlns:xhtml="http://www.w3.org/1999/xhtml" cols="2"><xhtml:colgroup><xhtml:col width="77%"/><xhtml:col width="23%"/></xhtml:colgroup><xhtml:tbody><xhtml:tr><xhtml:th><Emphasis>Column (1)</Emphasis></xhtml:th><xhtml:th><Emphasis>Column (2)</Emphasis></xhtml:th></xhtml:tr><xhtml:tr><xhtml:th><Emphasis>Person, couple or member of a polygamous marriage</Emphasis></xhtml:th><xhtml:th><Emphasis>Amount</Emphasis></xhtml:th></xhtml:tr><xhtml:tr><xhtml:td>(1) Single applicant or lone parent—</xhtml:td><xhtml:td/></xhtml:tr><xhtml:tr><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td></xhtml:tr><xhtml:tr><xhtml:td><P3 DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1/part/1/paragraph/2/bn1" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/part/1/paragraph/2/bn1" id="schedule-1-part-1-paragraph-2-bn1" shortId="schedule-1-paragraph-2-b"><Pnumber><Substitution ChangeId="key-a2" CommentaryRef="key-a2">b</Substitution></Pnumber><P3para><Text><Substitution ChangeId="key-a2" CommentaryRef="key-a2"> who has attained the qualifying age for state pension credit</Substitution> </Text></P3para></P3></xhtml:td><xhtml:td>    <Substitution ChangeId="key-a3" CommentaryRef="key-a3">£256.00</Substitution></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td>(2) Couple—</xhtml:td><xhtml:td/></xhtml:tr><xhtml:tr><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td></xhtml:tr><xhtml:tr><xhtml:td><P3 DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1/part/1/paragraph/2/bn2" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/part/1/paragraph/2/bn2" id="schedule-1-part-1-paragraph-2-bn2" shortId="schedule-1-paragraph-2-b"><Pnumber><Substitution ChangeId="key-a4" CommentaryRef="key-a4">b</Substitution></Pnumber><P3para><Text><Substitution ChangeId="key-a4" CommentaryRef="key-a4"> where one or both members have attained the qualifying age for state pension credit</Substitution> </Text></P3para></P3></xhtml:td><xhtml:td>    <Substitution ChangeId="key-a5" CommentaryRef="key-a5">£383.35</Substitution></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td>(3)<CommentaryRef Ref="key-a1"/>...</xhtml:td><xhtml:td/></xhtml:tr><xhtml:tr><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td></xhtml:tr><xhtml:tr><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td><xhtml:td><CommentaryRef Ref="key-a1"/>. . .</xhtml:td></xhtml:tr><xhtml:tr><xhtml:td>(4) If the applicant is a member of a polygamous marriage and one or more members of the marriage  <Substitution ChangeId="key-a6" CommentaryRef="key-a6">has attained the qualifying age for state pension credit</Substitution>—</xhtml:td><xhtml:td/></xhtml:tr><xhtml:tr><xhtml:td><P3 DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1/part/1/paragraph/2/an4" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/part/1/paragraph/2/an4" id="schedule-1-part-1-paragraph-2-an4" shortId="schedule-1-paragraph-2-a"><Pnumber>a</Pnumber><P3para><Text>for the applicant and one other party to the marriage;</Text></P3para></P3></xhtml:td><xhtml:td><Substitution ChangeId="key-a7" CommentaryRef="key-a7">£383.35</Substitution></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td><P3 DocumentURI="http://www.legislation.gov.uk/ssi/2012/319/schedule/1/part/1/paragraph/2/bn4" IdURI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/part/1/paragraph/2/bn4" id="schedule-1-part-1-paragraph-2-bn4" shortId="schedule-1-paragraph-2-b"><Pnumber>b</Pnumber><P3para><Text>for each additional party to the marriage who is a member of the same household as the applicant.</Text></P3para></P3></xhtml:td><xhtml:td>    <Substitution ChangeId="key-a8" CommentaryRef="key-a8">£127.35</Substitution></xhtml:td></xhtml:tr></xhtml:tbody></xhtml:table></Tabular></P1></Part></ScheduleBody></Schedule></Schedules></Secondary><Commentaries><Commentary id="key-a1" Type="F"><Para><Text>Words in <CitationSubRef id="cjwxxxau4-00006" SectionRef="schedule-1-paragraph-2" URI="http://www.legislation.gov.uk/id/ssi/2012/319/schedule/1/paragraph/2">sch. 1 para. 2</CitationSubRef> omitted (1.2.2021) by virtue of <Citation URI="http://www.legislation.gov.uk/id/ssi/2020/413" id="cjwxxxau4-00007" Class="ScottishStatutoryInstrument" Year="2020" Number="413" Title="The Council Tax Reduction (Scotland) Amendment (No. 4) Regulations 2020">The Council Tax Reduction (Scotland) Amendment (No. 4) Regulations 2020 (S.S.I. 2020/413)</Citation>, <CitationSubRef CitationRef="cjwxxxau4-00007" id="cjwxxxau4-00008" SectionRef="regulation-1" URI="http://www.legislation.gov.uk/id/ssi/2020/413/regulation/1">regs. 1</CitationSubRef>, <CitationSubRe