</TitleBlock><ScheduleBody><Part DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/schedule/2/part/1" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/schedule/2/part/1" NumberOfProvisions="2" id="schedule-2-part-1" RestrictExtent="E+W" RestrictStartDate="2026-01-23"><Number>PART 1</Number><Title>Personal allowances</Title><P1group RestrictExtent="E+W" RestrictStartDate="2026-01-23"><Title>Personal allowance</Title><P1 DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/schedule/2/paragraph/1" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/schedule/2/paragraph/1" id="schedule-2-paragraph-1"><Pnumber><CommentaryRef Ref="key-a6"/>1</Pnumber><P1para><Text>The amount specified in column (2) below in respect of each person or couple specified in column (1) is the amount specified for the purposes of paragraph 1(1)(a) of Schedule 1.</Text><Tabular Orientation="portrait"><xhtml:table xmlns:xhtml="http://www.w3.org/1999/xhtml" cols="2"><xhtml:colgroup><xhtml:col width="107.45pt"/><xhtml:col width="107.45pt"/></xhtml:colgroup><xhtml:thead><xhtml:tr><xhtml:th xmlns:fo="http://www.w3.org/1999/XSL/Format" colspan="1" fo:border-top-color="black" fo:border-top-width="0.5pt" fo:border-top-style="solid" rowspan="1"><Strong><Substitution ChangeId="key-a7" CommentaryRef="key-a7">Column  (1)</Substitution></Strong></xhtml:th><xhtml:th xmlns:fo="http://www.w3.org/1999/XSL/Format" colspan="1" fo:border-top-color="black" fo:border-top-width="0.5pt" fo:border-top-style="solid" rowspan="1"><Strong><Substitution ChangeId="key-a7" CommentaryRef="key-a7">Column (2)</Substitution></Strong></xhtml:th></xhtml:tr><xhtml:tr><xhtml:th xmlns:fo="http://www.w3.org/1999/XSL/Format" colspan="1" fo:border-bottom-style="solid" fo:border-top-width="0.5pt" fo:border-bottom-width="0.5pt" rowspan="1" fo:border-top-color="black" fo:border-bottom-color="black" fo:border-top-style="solid"><Strong><Substitution ChangeId="key-a7" CommentaryRef="key-a7">Person, couple or polygamous marriage</Substitution></Strong></xhtml:th><xhtml:th xmlns:fo="http://www.w3.org/1999/XSL/Format" colspan="1" fo:border-bottom-style="solid" fo:border-top-width="0.5pt" fo:border-bottom-width="0.5pt" rowspan="1" fo:border-top-color="black" fo:border-bottom-color="black" fo:border-top-style="solid"><Strong><Substitution ChangeId="key-a7" CommentaryRef="key-a7">Amount</Substitution></Strong></xhtml:th></xhtml:tr></xhtml:thead><xhtml:tbody><xhtml:tr><xhtml:td colspan="1" rowspan="1"><P2 DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/schedule/2/paragraph/1/1" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/schedule/2/paragraph/1/1" id="schedule-2-paragraph-1-1"><Pnumber><Substitution ChangeId="key-a7" CommentaryRef="key-a7">1</Substitution></Pnumber><P2para><Text><Substitution ChangeId="key-a7" CommentaryRef="key-a7">Single applicant or lone parent who has attained pensionable age</Substitution></Text></P2para></P2></xhtml:td><xhtml:td colspan="1" rowspan="1"><Substitution ChangeId="key-a7" CommentaryRef="key-a7"><Substitution ChangeId="key-a8" CommentaryRef="key-a8">£256.00</Substitution></Substitution></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td colspan="1" rowspan="1"><P2 DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/schedule/2/paragraph/1/2" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/schedule/2/paragraph/1/2" id="schedule-2-paragraph-1-2"><Pnumber><Substitution ChangeId="key-a7" CommentaryRef="key-a7">2</Substitution></Pnumber><P2para><Text><Substitution ChangeId="key-a7" CommentaryRef="key-a7">Couple where one or both members have attained pensionable age</Substitution></Text></P2para></P2></xhtml:td><xhtml:td colspan="1" rowspan="1"><Substitution ChangeId="key-a7" CommentaryRef="key-a7"><Substitution ChangeId="key-a9" CommentaryRef="key-a9">£383.35</Substitution></Substitution></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td xmlns:fo="http://www.w3.org/1999/XSL/Format" colspan="1" fo:border-bottom-style="solid" fo:border-bottom-color="black" fo