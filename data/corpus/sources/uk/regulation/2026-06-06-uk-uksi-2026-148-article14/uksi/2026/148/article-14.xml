</P3para>
</P3>
<P3 DocumentURI="http://www.legislation.gov.uk/uksi/2026/148/article/14/c/made" IdURI="http://www.legislation.gov.uk/id/uksi/2026/148/article/14/c" id="article-14-c">
<Pnumber>c</Pnumber>
<P3para>
<Text>in paragraph (1)(c) for “£29.20” substitute <InlineAmendment>“£30.30”</InlineAmendment>;</Text>
</P3para>
</P3>
<P3 DocumentURI="http://www.legislation.gov.uk/uksi/2026/148/article/14/d/made" IdURI="http://www.legislation.gov.uk/id/uksi/2026/148/article/14/d" id="article-14-d">
<Pnumber>d</Pnumber>
<P3para>
<Text>in paragraph (2)(a) for “£77.05” substitute <InlineAmendment>“£80.00”</InlineAmendment>; and</Text>
</P3para>
</P3>
<P3 DocumentURI="http://www.legislation.gov.uk/uksi/2026/148/article/14/e/made" IdURI="http://www.legislation.gov.uk/id/uksi/2026/148/article/14/e" id="article-14-e">
<Pnumber>e</Pnumber>
<P3para>
<Text>in paragraph (2)(b) for “£29.20” substitute <InlineAmendment>“£30.30”</InlineAmendment>.</Text>
</P3para>
</P3>
</P1para>
