				</ukm:Metadata><Secondary><Body DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/body" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/body" NumberOfProvisions="40" NumberFormat="default" RestrictExtent="E+W" RestrictStartDate="2026-01-23"><Part DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/part/4" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/part/4" NumberOfProvisions="5" id="part-4" RestrictExtent="E+W" RestrictStartDate="2026-01-23"><Number>PART 4</Number><Title id="p00144">Prescribed classes of person who must not be included in an authority’s scheme</Title><P1group RestrictExtent="E+W" RestrictStartDate="2013-11-28"><Title>Persons whose capital exceeds £16,000</Title><P1 DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/regulation/30" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/regulation/30" id="regulation-30">
<Pnumber><CommentaryRef Ref="key-a2"/>30</Pnumber>
<P1para>
<P2 DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/regulation/30/1" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/regulation/30/1" id="regulation-30-1">
<Pnumber>1</Pnumber>
<P2para><Text>The class of person described in this regulation consists of any person whose capital exceeds £16,000.</Text>
</P2para>
</P2>
<P2 DocumentURI="http://www.legislation.gov.uk/wsi/2013/3029/regulation/30/2" IdURI="http://www.legislation.gov.uk/id/wsi/2013/3029/regulation/30/2" id="regulation-30-2">
<Pnumber>2</Pnumber>
<P2para>
<Text>Capital for the purposes of paragraph (1) is to be calculated in accordance with Schedule 1 (pensioners) or Schedule 6 (persons who are not pensioners).</Text>
</P2para>
</P2>
</P1para>
</P1></P1group></Part></Body></Secondary><Commentaries><Commentary Type="I" id="key-a2"><Para><Text>Reg. 30 in force at 28.11.2013, see <CitationSubRef id="ndb74e210f2464e1c" SectionRef="regulation-1-2" URI="http://www.legislation.gov.uk/id/wsi/2013/3029/regulation/1/2" Operative="true">reg. 1(2)</CitationSubRef></Text></Para></Commentary></Commentaries></Legislation>