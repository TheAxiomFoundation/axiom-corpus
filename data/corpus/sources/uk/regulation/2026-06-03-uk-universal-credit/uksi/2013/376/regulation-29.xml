2013" Type="words omitted" EffectId="key-472c21291a42b9cc01d3bb99c5389aae" AffectedExtent="E+W+S" Modified="2026-04-30T10:06:09Z" AffectedClass="UnitedKingdomStatutoryInstrument" AffectingNumber="618" AffectingURI="http://www.legislation.gov.uk/id/uksi/2020/618" AffectedProvisions="Table of Contents" RequiresApplied="false" Notes="This amendment not applied to legislation.gov.uk. The table of contents for this legislation will be dynamically updated when its provisions are revised" AffectedURI="http://www.legislation.gov.uk/id/uksi/2013/376" URI="http://www.legislation.gov.uk/id/effect/key-472c21291a42b9cc01d3bb99c5389aae" Row="13"><ukm:AffectedTitle>The Universal Credit Regulations 2013</ukm:AffectedTitle><ukm:AffectedProvisions><ukm:Section xmlns:err="http://www.legislation.gov.uk/namespaces/error" Ref="section" URI="http://www.legislation.gov.uk/id/uksi/2013/376/section" err:Ref="Section missing in legislation" Missing="true">Table of Contents</ukm:Section></ukm:AffectedProvisions><ukm:AffectingTitle>The Social Security (Income and Capital) (Miscellaneous Amendments) Regulations 2020</ukm:AffectingTitle><ukm:AffectingProvisions><ukm:Section Ref="regulation-8-3-a" URI="http://www.legislation.gov.uk/id/uksi/2020/618/regulation/8/3/a">reg. 8(3)(a)</ukm:Section></ukm:AffectingProvisions><ukm:CommencementAuthority><ukm:Section Ref="regulation-1" URI="http://www.legislation.gov.uk/id/uksi/2020/618/regulation/1">reg. 1</ukm:Section></ukm:CommencementAuthority><ukm:InForceDates><ukm:InForce Date="2020-07-15" Qualification="wholly in force"/></ukm:InForceDates></ukm:UnappliedEffect></ukm:UnappliedEffects></ukm:SecondaryMetadata>
