				</ukm:Metadata><Secondary><Schedules RestrictExtent="E+W+S" RestrictStartDate="2026-04-06"><Schedule DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4" NumberOfProvisions="40" id="schedule-4" RestrictStartDate="2026-04-06"><Number>SCHEDULE 4</Number><TitleBlock><Title>Housing costs element for renters</Title></TitleBlock><ScheduleBody><Part DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4/part/3" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4/part/3" NumberOfProvisions="15" id="schedule-4-part-3" RestrictStartDate="2026-04-06"><Number><Strong>PART 3</Strong></Number><Title>General provisions about calculation of amount of housing costs element for renters</Title><Pblock DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4/part/3/crossheading/housing-cost-contributions" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4/part/3/crossheading/housing-cost-contributions" NumberOfProvisions="4" id="schedule-4-part-3-crossheading-housing-cost-contributions" RestrictStartDate="2026-04-06"><Title><Emphasis>Housing cost contributions</Emphasis></Title><P1group RestrictStartDate="2013-04-29"><Title>Housing cost contributions</Title><P1 DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4/paragraph/13" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4/paragraph/13" id="schedule-4-paragraph-13"><Pnumber>13</Pnumber><P1para><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4/paragraph/13/1" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4/paragraph/13/1" id="schedule-4-paragraph-13-1"><Pnumber>1</Pnumber><P2para><Text>In calculating the amount of the housing costs element under Part 4 or 5 of this Schedule, a deduction is to be made in respect of each non-dependant who is a member of the renter's extended benefit unit.</Text></P2para></P2><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4/paragraph/13/2" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4/paragraph/13/2" id="schedule-4-paragraph-13-2"><Pnumber>2</Pnumber><P2para><Text>Paragraph (1) is subject to paragraphs 15 and 16.</Text></P2para></P2><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2013/376/schedule/4/paragraph/13/3" IdURI="http://www.legislation.gov.uk/id/uksi/2013/376/schedule/4/paragraph/13/3" id="schedule-4-paragraph-13-3"><Pnumber>3</Pnumber><P2para><Text>Any amount to be deducted under sub-paragraph (1) is referred to in this Schedule as a  “<Term id="term-housing-cost-contribution">housing cost contribution</Term>”.</Text></P2para></P2></P1para></P1></P1group></Pblock></Part></ScheduleBody></Schedule></Schedules></Secondary></Legislation>