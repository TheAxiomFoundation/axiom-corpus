				</ukm:Metadata><Secondary><Schedules RestrictExtent="E+W" RestrictStartDate="2026-02-13"><Schedule DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2" NumberOfProvisions="11" id="schedule-2" RestrictExtent="E+W" RestrictStartDate="2026-02-13"><Number>SCHEDULE 2</Number><TitleBlock><Title>Applicable amounts</Title></TitleBlock><ScheduleBody><Part DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/1" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/1" NumberOfProvisions="2" id="schedule-2-part-1" RestrictExtent="E+W" RestrictStartDate="2026-02-13"><Number>PART 1</Number><Title>Personal allowances</Title><P1group RestrictExtent="E+W" RestrictStartDate="2026-02-13"><Title>Child or young person amounts</Title><P1 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/part/1/paragraph/2" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/part/1/paragraph/2" id="schedule-2-part-1-paragraph-2" shortId="schedule-2-paragraph-2"><Pnumber><CommentaryRef Ref="key-a1"/>2</Pnumber><P1para><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/paragraph/2/1" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/paragraph/2/1" id="schedule-2-paragraph-2-1"><Pnumber>1</Pnumber><P2para><Text>The amounts specified in column (2) below in respect of each person specified in column (1) are the amounts, for the relevant period specified in column (1), specified for the purposes of paragraph 6(1)(b) of Schedule 1.</Text><Tabular Orientation="portrait"><xhtml:table xmlns:xhtml="http://www.w3.org/1999/xhtml" cols="2"><xhtml:colgroup><xhtml:col width="213.2pt"/><xhtml:col width="213.2pt"/></xhtml:colgroup><xhtml:thead><xhtml:tr><xhtml:th xmlns:fo="http://www.w3.org/1999/XSL/Format" rowspan="1" colspan="1" fo:border-top-style="solid" fo:border-top-width="0.5pt" fo:border-top-color="black" fo:border-bottom-style="solid" fo:border-bottom-width="0.5pt" fo:border-bottom-color="black"><Para><Text><Emphasis>Column (1)</Emphasis></Text></Para><Para><Text><Emphasis>Child or young person</Emphasis></Text></Para></xhtml:th><xhtml:th xmlns:fo="http://www.w3.org/1999/XSL/Format" rowspan="1" colspan="1" fo:border-top-style="solid" fo:border-top-width="0.5pt" fo:border-top-color="black" fo:border-bottom-style="solid" fo:border-bottom-width="0.5pt" fo:border-bottom-color="black"><Para><Text><Emphasis>Column (2)</Emphasis></Text></Para><Para><Text><Emphasis>Amount</Emphasis></Text></Para></xhtml:th></xhtml:tr></xhtml:thead><xhtml:tbody><xhtml:tr><xhtml:td rowspan="1" colspan="1"><P><Text>Person in respect of the period—</Text></P></xhtml:td><xhtml:td rowspan="1" colspan="1"/></xhtml:tr><xhtml:tr><xhtml:td rowspan="1" colspan="1"><OrderedList Decoration="parens" Type="alpha"><ListItem><Para><Text>beginning on that person’s date of birth and ending on the day preceding the first Monday in September following that person’s sixteenth birthday;</Text></Para></ListItem></OrderedList></xhtml:td><xhtml:td rowspan="1" colspan="1"><OrderedList Decoration="parens" Type="alpha"><ListItem><Para><Text>  <Substitution ChangeId="key-a2" CommentaryRef="key-a2">£87.88</Substitution>;</Text></Para></ListItem></OrderedList></xhtml:td></xhtml:tr><xhtml:tr><xhtml:td xmlns:fo="http://www.w3.org/1999/XSL/Format" rowspan="1" colspan="1" fo:border-bottom-style="solid" fo:border-bottom-width="0.5pt" fo:border-bottom-color="black"><OrderedList Decoration="parens" Type="alpha" Start="2"><ListItem><Para><Text>beginning on the first Monday in September following that person’s sixteenth birthday and ending on the day preceding that person’s twentieth birthday.</Text></Para></ListItem></OrderedList></xhtml:td><xhtml:td xmlns:fo="http://www.w3.org/1999/XSL/Format" rowspan="1" colspan="1" fo:border-bottom-style="solid" fo:border-bottom-width="0.5pt" fo:border-bottom-color="black"><OrderedList Decoration="parens" Type="alpha" Start="2"><ListItem><Para><Text>  <Substitution ChangeId="key-a2" CommentaryRef="key-a2">£87.88</Substitution>.</Text></Para></ListItem></OrderedList></xhtml:td></xhtml:tr></xhtml:tbody></xhtml:table></Tabular></P2para></P2><P2 DocumentURI="http://www.legislation.gov.uk/uksi/2012/2885/schedule/2/paragraph/2/2" IdURI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/paragraph/2/2" id="schedule-2-paragraph-2-2"><Pnumber>2</Pnumber><P2para><Text>In column (1) of the table “the first Monday in September” means the Monday which first occurs in the month of September in any year.</Text></P2para></P2></P1para></P1></P1group></Part></ScheduleBody></Schedule></Schedules></Secondary><Commentaries><Commentary id="key-a1" Type="I"><Para><Text>Sch. 2 para. 2 in force at 27.11.2012, see <CitationSubRef id="ccd8e420231116212520071Z" URI="http://www.legislation.gov.uk/id/uksi/2012/2885/regulation/1/1" SectionRef="regulation-1-1">reg. 1(1)</CitationSubRef></Text></Para></Commentary><Commentary id="key-a2" Type="F"><Para><Text>Sum in <CitationSubRef id="c3h76wcm6-00007" SectionRef="schedule-2-paragraph-2-1" URI="http://www.legislation.gov.uk/id/uksi/2012/2885/schedule/2/paragraph/2/1">Sch. 2 para. 2(1)</CitationSubRef> Table  substituted (13.2.2026 with application in relation to financial years beginning on or after 1.4.2026) by <Citation URI="http://www.legislation.gov.uk/id/uksi/2026/27" id="c3h76wcm6-00008" Class="UnitedKingdomStatutoryInstrument" Year="2026" Number="27" Title="The Council Tax Reduction Schemes (Prescribed Requirements) (England) (Amendment) Regulations 2026">The Council Tax Reduction Schemes (Prescribed Requirements) (England) (Amendment) Regulations 2026 (S.I. 2026/27)</Citation>, <CitationSubRef CitationRef="c3h76wcm6-00008" id="c3h76wcm6-00009" SectionRef="regulation-1-1" URI="http://www.legislation.gov.uk/id/uksi/2026/27/regulation/1/1">regs. 1(1)</CitationSubRef>, <CitationSubRef CitationRef="c3h76wcm6-00008" id="c3h76wcm6-00010" Section