    <div id="custom-accessibility-focus"></div>
    <script>
    (function() {
        const focusBox = document.getElementById('custom-accessibility-focus');
        let isKeyboard = false;

        document.addEventListener('keydown', (e) => { if (e.key === 'Tab') isKeyboard = true; });
        document.addEventListener('mousedown', () => { isKeyboard = false; if (focusBox) focusBox.style.display = 'none'; });

        // TOOLBOX: SVG Icon Generator
        function getFileIcon(ext) {
            const color = "#0056b3";
            return `<svg class="afa-file-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" fill="${color}"/>
                <path d="M14 2V8H20L14 2Z" fill="#ffffff" fill-opacity="0.4"/>
                <text x="12" y="17" font-family="Arial" font-size="5.5px" font-weight="bold" fill="white" text-anchor="middle">${ext.toUpperCase()}</text>
            </svg>`;
        }

        function moveBox(target) {
            if (!isKeyboard || !focusBox) return;
            
            // Find the actual interactive parent
            const el = target.closest('a, button, input, select, textarea, .h-button');
            if (!el) { focusBox.style.display = 'none'; return; }

            // SNAP LOGIC: We want the biggest visual element (Image > Div > Link)
            let boxArea = el;
            const img = el.querySelector('img');
            const div = el.querySelector('div');
            
            if (img && img.offsetHeight > 5) boxArea = img;
            else if (div && div.offsetHeight > 5) boxArea = div;

            const rect = boxArea.getBoundingClientRect();
            if (rect.width === 0 || rect.height === 0) return;

            // Check if element is in a fixed header
            const isFixed = !!el.closest('header') || window.getComputedStyle(el).position === 'fixed';
            
            focusBox.style.display = 'block';
            focusBox.style.position = isFixed ? 'fixed' : 'absolute';
            focusBox.style.width = (rect.width + 10) + 'px';
            focusBox.style.height = (rect.height + 10) + 'px';
            focusBox.style.left = (rect.left + (isFixed ? 0 : window.scrollX) - 5) + 'px';
            focusBox.style.top = (rect.top + (isFixed ? 0 : window.scrollY) - 5) + 'px';
        }

          function runMasterEnforcement() {
            const items = document.querySelectorAll('input, textarea, select, a, button, .h-button, .h-element a, .h-column a');
            
            items.forEach(el => {
                // 1. FORCED TABINDEX
                if (el.getAttribute('tabindex') !== '0' && !el.disabled) {
                    el.setAttribute('tabindex', '0');
                }

                // 2. THE NUCLEAR AUTOCOMPLETE ENGINE
                // We run this EVERY loop, no "afa-ready" gate, to fight theme resets
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.tagName === 'SELECT') {
                    const attr = (el.name + el.id + el.className + el.placeholder + (el.labels?.[0]?.innerText || "")).toLowerCase();
                    let type = "";

                    if (attr.includes('first') || attr.includes('given')) type = 'given-name';
                    else if (attr.includes('last') || attr.includes('family')) type = 'family-name';
                    else if (attr.includes('name')) type = 'name';
                    else if (attr.includes('email')) type = 'email';
                    else if (attr.includes('tel') || attr.includes('phone') || attr.includes('mobile')) type = 'tel';
                    else if (attr.includes('address-1') || attr.includes('street')) type = 'address-line1';
                    else if (attr.includes('city') || attr.includes('town')) type = 'address-level2';
                    else if (attr.includes('state') || attr.includes('province')) type = 'address-level1';
                    else if (attr.includes('zip') || attr.includes('post') || attr.includes('postal')) type = 'postal-code';

                    if (type !== "") {
                        // We set BOTH the attribute and the direct property
                        el.setAttribute('autocomplete', type);
                        el.autocomplete = type; 
                    }
                }




                // 3. LABELS & ICONS (Syncing Visual Text with ARIA)
                if (!el.classList.contains('afa-ready')) {
                    const href = (el.getAttribute('href') || "").toLowerCase();
                    
                    // A. Determine Visual Text vs. Slug
                    let visibleText = el.innerText.trim();
                    let titleAttr = el.getAttribute('title') || "";
                    let imgAlt = el.querySelector('img')?.getAttribute('alt') || "";
                    
                    // B. Extension Detection
                    let ext = "";
                    if (href.endsWith('.pdf')) ext = "pdf";
                    else if (href.endsWith('.doc') || href.endsWith('.dot')) ext = "doc";
                    else if (href.endsWith('.docx')) ext = "docx";
                    else if (href.endsWith('.xls') || href.endsWith('.xlsx')) ext = "xls";

                    if (ext !== "" && !el.querySelector('.afa-file-icon')) {
                        el.insertAdjacentHTML('beforeend', getFileIcon(ext));
                    }

                    // C. The Sync Logic: 
                    // We start with visible text. If it's empty or generic, we build from slug.
                    let finalName = visibleText || titleAttr || imgAlt;

                    if (!finalName || finalName.toLowerCase() === 'read more') {
                        let slug = href.split('/').filter(Boolean).pop() || "";
                        slug = slug.split(/[?#]/)[0].replace(/\.(pdf|doc|docx|dot|xls|xlsx)$/i, '');
                        finalName = slug.split(/[-_.]/).filter(w => w.length > 0)
                                        .map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                    }

                    // D. Final Polish
                    if (finalName) {
                        // If it's a file, we append the extension to the existing name
                        const suffix = ext ? ` (${ext.toUpperCase()} file)` : "";
                        el.setAttribute('aria-label', finalName + suffix);
                    }

                    el.classList.add('afa-ready');
                }
            });
        }


        document.addEventListener('focusin', (e) => moveBox(e.target));
        document.addEventListener('focusout', () => { focusBox.style.display = 'none'; });

        setInterval(runMasterEnforcement, 2000);
        runMasterEnforcement();
    })();
    </script>
