t">871.86</entry><entry/><entry>898.96</entry></row><row><entry>Clause 9</entry><entry/><entry align="right">918.54</entry><entry/><entry>947.09</entry></row><row><entry nameend="COLSPEC6" namest="col1"><emphasis style="italic"><citation jurisdiction="nz">Schedule 5, <extref href="DLM6784895" id="LMS1577764">Part 3</extref></citation> (Disability allowance income limits)</emphasis></entry></row><row><entry>Clause 10</entry><entry/><entry align="right">675.60</entry><entry/><entry>696.60</entry></row><row><entry>Clause 11</entry><entry/><entry align="right">843.78</entry><entry/><entry>870.00</entry></row><row><entry>Clause 12</entry><entry/><entry align="right">1,256.07</entry><entry/><entry>1,295.11</entry></row><row><entry>Clause 13</entry><entry/><entry align="right">942.23</entry><entry/><entry>971.51</entry></row><row><entry>Clause 14</entry><entry/><entry align="right">992.74</entry><entry/><entry>1,023.59</entry></row></tbody></tgroup></table></legtable></para></head1><head1 id="LMS1574011" toc="yes"><label denominator="yes">Part 2</label><heading>Increase to superannuation entitlements</heading><para><legtable><summary>The following table is small in size and has 3 columns. Column 1 is headed Provision amended and includes a subheading. Column 2 is headed Old amount ($). Column 3 is headed New amount ($).</summary><table align="left" colsep="0" fontsize="9.5" frame="none" id="LMS1574010" leading="10.5" rowsep="0"><tgroup cols="5"><colspec colname="col1" colwidth="2.56*"/><colspec colname="col4" colwidth="12.05pt"/><colspec colname="col5" colwidth="1.75*"/><colspec colname="COLSPEC11" colwidth="12.05pt"/><colspec colname="COLSPEC10" colwidth="1.64*"/><thead><row><entry colsep="0"><emphasis style="bold">Provision amended</emphasis></entry><entry colsep="0"/><entry align="right"><emphasis style="bold">Old amount ($)</emphasis></entry><entry/><entry align="right"><emphasis style="bold">New amount ($)</emphasis></entry></row></thead><tbody><row><entry align="left" nameend="COLSPEC10" namest="col1"><emphasis style="italic"><citation jurisdiction="nz">Schedule 1, <extref href="LMS424862" id="LMS1577765">Part 2</extref></citation> (Rates saved by Schedule 1AA)</emphasis></entry></row><row><entry>Clause 1(a)</entry><entry/><entry align="right">952.94</entry><entry/><entry align="right">984.28</entry></row></tbody></tgroup></table></legtable></para></head1><head1 id="LMS1574013" toc="yes"><label denominator="yes">Part 3</label><heading>Discretionary increase relating to clause 3 of Part 1 of Schedule 1 of the New Zealand Superannuation and Retirement Income Act 2001</heading><para><legtable><summary>The following table is small in size and has 3 columns. Column 1 is headed Provision amended and includes a subheading. Column 2 is headed Old amount ($). Column 3 is headed New amount ($).</summary><table align="left" fontsize="9.5" id="LMS1574012" leading="10.5" frame="none" colsep="0" rowsep="0"><tgroup cols="5"><colspec colname="col1" colwidth="2.28*"/><colspec colname="COLSPEC0" colwidth="12.05pt"/><colspec align="right" colname="col2" colwidth="1.56*"/><colspec colname="COLSPEC1" colwidth="11.54pt"/><colspec align="right" colname="col3" colwidth="1.47*"/><thead><row valign="bottom"><entry><emphasis style="bold">Provision amended</emphasis></entry><entry/><entry><emphasis style="bold">Old amount ($)</emphasis></entry><entry/><entry><emphasis style="bold">New amount ($)</emphasis></entry></row></thead><tbody><row><entry nameend="col3" namest="col1"><emphasis style="italic"><citation jurisdiction="nz">Schedule 1, <extref href="LMS424819" id="LMS1577766">Part 1</extref></citation> (Rates generally)</emphasis></entry></row><row><entry>Clause 3</entry><entry/><entry>56.58</entry><entry/><entry>58.34</entry></row></tbody></tgroup></table></legtable></para></head1></schedule.misc></schedule></schedule.group><end id="LMS1574017"><signature-block><sig.para align="right">Rachel Hayward,<brk/>Clerk of the Executive Council.</sig.para></signature-block><explnote id="LMS1574016" rule-after="yes" rule-before="yes" series="statutory-regulation" date.as.at="2026-03-02" date.first.valid="2026-04-01" gazette-only="no" imperial="no" date.gazetted="2026-03-05" date.signed="2026-03-02" sr.no="36" year="2026" date.terminated="nulldate" sr.type="order"><heading>Explanatory note</heading><explnote.subhead2>This note is not part of the order but is intended to indicate its general effect.</explnote.subhead2><para><text>This order, which comes into force on 1 April 2026, increases a range of benefits, allowances, asset limits, superannuation entitlements, etc, that are payable on and after that date. The increases reflect both mandatory adjustments and discretionary increases.</text></para><para><text>Where an annual consumers price index (<def-term id="LMS1574015">CPI</def-term>) increase is required, it reflects the increase of 3.11% in the New Zealand Consumers Price Index from the December 2024 quarter to the December 2025 quarter (calculated for all quarters using the New Zealand Consumers Price Index (All Groups)).</text></para><para><text>Annual CPI increases are required under <citation jurisdiction="nz"><extref href="DLM6784028" id="LMS1574051">section 453</extref> of the Social Security Act 2018</citation> for the following benefits:</text><list><item><label denominator="yes"/><para><text>jobseeker support:</text></para></item><item><label denominator="yes"/><para><text>sole parent support:</text></para></item><item><label denominator="yes"/><para><text>supported living payment:</text></para></item><item><label denominator="yes"/><para><text>orphan’s benefit:</text></para></item><item><label denominator="yes"/><para><text>unsupported child’s benefit:</text></para></item><item><label denominator="yes"/><para><text>youth payment and young parent payment:</text></para></item><item><label denominator="yes"/><para><text>former widows’ benefit:</text></para></item><item><label denominator="yes"/><para><text>former domestic purposes benefit:</text></para></item><item><label denominator="yes"/><para><text>long-term hospital patient benefit.</text></para></item></list></para><para><text>Those increases are set out in <emphasis style="italic"><citation jurisdiction="nz"><intref href="LMS1574004" id="LMS1577767">Part 1</intref> of Schedule 1</citation></emphasis>.</text></para><para><text>Annual CPI increases are also required, under <citation jurisdiction="nz"><extref href="DLM114207" id="LMS1574053">section 15</extref> of the New Zealand Superannuation and Retirement Income Act 2001</citation>, for superannuation entitlements. Those increases are set out in <emphasis style="italic"><citation jurisdiction="nz"><intref href="LMS1574006" id="LMS1577768">Part 2</intref> of Schedule 1</citation></emphasis>. While the increases may sometimes be more than the CPI increases to meet the requirements in <citation jurisdiction="nz"><extref href="DLM114207" id="LMS1574055">sections 15(3)</extref> and <extref href="DLM114216" id="LMS1574056">16</extref> of the New Zealand Superannuation and Retirement Income Act 2001</citation> (that the increases maintain a specified relationship to the net average wage and also maintain the proportional relationship of specified rates), no further increases are required this year to meet those requirements.</text></para><para><text>The discretionary increases made under <citation jurisdiction="nz"><extref href="DLM6784026" id="LMS1574057">section 452</extref> of the Social Security Act 2018</citation> are in respect of—</text><list><item><label denominator="yes"/><para><text>certain rates of benefits payable to beneficiaries set out in <citation jurisdiction="nz"><extref href="DLM6784867" id="LMS1577769">Parts 6</extref> and <extref href="DLM6784880" id="LMS1577770">9</extref> of Schedule 4 of the Social Security Act 2018</citation>:</text></para></item><item><label denominator="yes"/><para><text>the various asset and income limits that are set out in <citation jurisdiction="nz"><extref href="DLM6784890" id="LMS1574059">Schedule 5</extref> of the Social Security Act 2018</citation> for receiving certain benefits and grants:</text></para></item><item><label denominator="yes"/><para><text>certain rates payable to superannuitants set out in <citation jurisdiction="nz"><extref href="DLM115004" id="LMS1574060">Schedule 1</extref> of the New Zealand Superannuation and Retirement Income Act 2001</citation>.</text></para></item></list></para><para><text>Those increases are set out in <emphasis style="italic"><citation jurisdiction="nz"><intref href="LMS1574014" id="LMS1574061">Schedule 2</intref></citation></emphasis>.</text></para><para><text>The CPI increase has been rounded to 2 decimal places for the purposes of this Explanatory note. However, increases to benefits and entitlements have been calculated on the basis of unrounded figures.</text></para><para><text>This order must be confirmed by an Act before the close of 30 June 2027. If it is not confirmed, it will be revoked on the close of that date. <emphasis style="italic">See</emphasis> <citation jurisdiction="nz"><extref href="DLM7298438" id="LMS1577771">subpart 3</extref> of Part 5 of the Legislation Act 2019</citation>.</text></para></explnote><promulgation><issue-authority>Issued under the authority of the <citation jurisdiction="nz"><leg-title href="DLM7298104" id="LMS1574018">Legislation Act 2019</leg-title></citation>.</issue-authority><gazette-date>Date of notification in <emphasis style="italic">Gazette</emphasis>: 5 March 2026.</gazette-date><admin-office>This order is administered by the <ministry>Ministry of Social Development</ministry>.</admin-office></promulgation></end></regulation>