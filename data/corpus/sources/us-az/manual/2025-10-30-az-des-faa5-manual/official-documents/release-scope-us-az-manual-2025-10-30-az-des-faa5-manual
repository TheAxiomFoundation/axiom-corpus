        <div class="ww_skin_page_toolbar"><div id="dropdown_button_container" class="dropdown_container dropdown_button_container_disabled"><a id="show_hide_all" class="ww_skin ww_behavior_dropdown_toggle ww_skin_dropdown_toggle" title="Page DropDown Toggle" href="#"><i class="far"></i></a><span class="ww_skin_page_toolbar_divider">&nbsp;</span></div><a class="ww_behavior_print ww_skin ww_skin_print" title="Print" href="#"><i class="fa"></i></a><!-- FAA Override changed target from _blank --><a class="ww_behavior_email ww_skin ww_skin_email" title="E-Mail" href="#" target="external_window"><i class="far"></i></a></div>
        <!-- was this helpful button -->
