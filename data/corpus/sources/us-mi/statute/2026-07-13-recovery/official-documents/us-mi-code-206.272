<h1>MCL - Section 206.272</h1>

<div class="row" style="padding-bottom: 7px; margin-top: -9px;">
    <div class="col-12" style="text-align: left;">
        <div>
            <span><a href="/Home/Document?objectName=mcl-206-272">Download Section</a></span>



        </div>
    </div>
</div>


<div class="row" style="padding-top: 7px;">
    <div class="col-12 text-center">
                    <span><a href="/Laws/MCL?objectName=mcl-chap206">Chapter 206</a></span><br>
                    <span><a href="/Laws/MCL?objectName=mcl-Act-281-of-1967">Act 281 of 1967</a></span><br>
                    <span><a href="/Laws/MCL?objectName=mcl-281-1967-1">281-1967-1</a></span><br>
                    <span><a href="/Laws/MCL?objectName=mcl-281-1967-1-5">281-1967-1-5</a></span><br>
    </div>
</div>
<div class="row" style="padding-bottom: 7px;">
    <div class="col-6" style="text-align:right">
                <span><a href="/Laws/MCL?objectName=mcl-206-271"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#5495F7" class="bi bi-caret-left-fill" viewBox="0 0 16 16" alt="" title=""><path d="m3.86 8.753 5.482 4.796c.646.566 1.658.106 1.658-.753V3.204a1 1 0 0 0-1.659-.753l-5.48 4.796a1 1 0 0 0 0 1.506z"></path></svg> Previous Section</a></span>
